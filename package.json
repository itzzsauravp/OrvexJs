{
  "name": "@itzzsauravp/alpha-orvexjs",
  "version": "0.1.0-alpha.1",
  "description": "A minimalist Web Framework",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "license": "MIT",
  "author": {
    "name": "Saurav Parajulee",
    "email": "social.saurav2003@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itzzsauravp/OrvexJs.git"
  },
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc",
    "lint": "oxlint",
    "format": "oxfmt src",
    "lint:fix": "oxlint --fix",
    "orvex": "npx ts-node ./src/example/server.ts",
    "orvex:dev": "npx tsx --watch ./src/example/server.ts",
    "orvex:test": "npx tsx --watch ./src/index.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "oxlint --deny-warnings",
      "oxfmt --write"
    ]
  }
}
